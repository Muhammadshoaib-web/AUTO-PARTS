{
  "name": "autoparts-ims",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "npm run --workspace=backend migration:run",
    "db:seed": "npm run --workspace=backend seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
