# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=autoparts_db
DB_USER=postgres
DB_PASS=yourpassword
DB_SYNC=false
DB_LOGGING=false
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_REFRESH_EXPIRY=7d

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── FBR Integration ─────────────────────────────────────────────────────────
FBR_BASE_URL=https://sandbox.fbr.gov.pk
FBR_API_KEY=your_fbr_api_key
FBR_POS_ID=your_pos_id

# ─── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── Rate Limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ─── Frontend URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
